keybind = global:cmd+;=toggle_quick_terminal
keybind = cmd+shift+r=prompt_tab_title
font-family = Hack
font-size = {{ if eq .chezmoi.hostname "rhs-endeavour" }}10{{ else }}13{{ end }}
confirm-close-surface = false

theme = TokyoNight Night

window-save-state = never
window-decoration = true
link-url = true
#font-thicken = {{ if eq .chezmoi.os "darwin" }}true{{ else }}false{{ end }}
font-thicken = true

adjust-cell-height = +10%

# Send Ctrl+Tab as CSI-u sequence for tmux window switching
keybind = ctrl+tab=text:\x1b[9;5u

