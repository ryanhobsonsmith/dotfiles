{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Configure keyd for caps -> esc (tap) / ctrl (hold)
# config hash: {{ include "dot_config/keyd/default.conf" | sha256sum }}

if ! command -v keyd >/dev/null 2>&1; then
  echo "Installing keyd..."
  sudo apt-get update
  sudo apt-get install -y keyd 2>/dev/null || {
    echo "keyd not in apt, building from source..."
    tmpdir=$(mktemp -d)
    git clone https://github.com/rvaiya/keyd "$tmpdir/keyd"
    cd "$tmpdir/keyd"
    make && sudo make install
    rm -rf "$tmpdir"
  }
fi

sudo mkdir -p /etc/keyd
sudo cp "$HOME/.config/keyd/default.conf" /etc/keyd/default.conf
sudo systemctl enable keyd
sudo systemctl restart keyd
echo "keyd configured: caps → esc (tap) / ctrl (hold)"
{{ end -}}
