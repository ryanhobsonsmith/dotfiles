# Force re-auth of aws profile
aws_sso_auth() {
  local profile="default"
  for arg in "$@"; do
    case $arg in
    --profile=*) profile="${arg#*=}" ;;
    *) profile="$arg" ;;
    esac
  done
  echo "Forcing AWS SSO re-auth for profile: $profile"
  aws sso logout --profile "$profile" >/dev/null 2>&1 || true
  rm -f ~/.aws/sso/cache/*.json 2>/dev/null || true
  aws sso login --profile "$profile"
}

aws_al_auth() {
  aws_sso_auth --profile=al-test
  aws sso login --profile=al-prod
}

# ── Claude Code session resume ───────────────────────────────
# Launch claude, resuming the most recent session in the current dir if one exists.
# Claude stores sessions in ~/.claude/projects/<encoded-cwd>/*.jsonl where the
# encoded cwd replaces both '/' and '.' with '-'.
claude_resume() {
  local encoded="${PWD//\//-}"
  encoded="${encoded//./-}"
  local proj_dir="$HOME/.claude/projects/$encoded"
  if ls "$proj_dir"/*.jsonl >/dev/null 2>&1; then
    claude --continue
  else
    claude
  fi
}

# ── Tmux session management ─────────────────────────────────
cts() {
  local dir="${1:-.}"
  dir="$(cd "$dir" && pwd)" || {
    echo "Invalid directory: $dir"
    return 1
  }
  local session_name="$(basename "$dir")"
  local sh="$(basename "$SHELL")"

  if ! tmux has-session -t "=$session_name" 2>/dev/null; then
    tmux new-session -d -s "$session_name" -c "$dir" -n "zsh"
    tmux new-window -t "$session_name:" -c "$dir" -n "claude" "$sh -ic 'claude_resume; exec $sh'"
    tmux select-window -t "$session_name:zsh"
  fi

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "=$session_name"
  else
    tmux attach-session -t "=$session_name"
  fi
}

ts() {
  local selected
  selected=$(find ~/algebralabs ~/projects -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf --reverse)
  [ -n "$selected" ] && cts "$selected"
}

# ── Algebra Labs worktree management ─────────────────────────
AL_REPO="$HOME/algebralabs/algebra-labs"

alwt() {
  if [ $# -eq 0 ] || { [ $# -eq 1 ] && [ "$1" = "." ]; }; then
    local git_root
    git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
      echo "Not in a git repo"
      return 1
    }
    cts "$git_root"
    return
  fi

  local branch_name="$1"
  local worktree_dir

  if [ -d "$branch_name" ]; then
    worktree_dir="$(cd "$branch_name" && pwd)"
  else
    worktree_dir="$(dirname "$AL_REPO")/$branch_name"
  fi

  if [ ! -d "$worktree_dir" ]; then
    (
      cd "$AL_REPO" || exit 1
      if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        git worktree add "$worktree_dir" "$branch_name"
      elif git show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
        git worktree add --track -b "$branch_name" "$worktree_dir" "origin/$branch_name"
      else
        git worktree add -b "$branch_name" "$worktree_dir" "origin/main"
      fi
    ) || return 1
  fi

  (cd "$worktree_dir" && pnpm wt:setup) || return 1
  cts "$worktree_dir"
}

alwt-stop() {
  local force="" worktree_dir=""
  while [ $# -gt 0 ]; do
    case "$1" in
    --force | -f)
      force="--force"
      shift
      ;;
    *)
      worktree_dir="$1"
      shift
      ;;
    esac
  done

  if [ -z "$worktree_dir" ]; then
    local git_toplevel
    git_toplevel="$(git rev-parse --show-toplevel 2>/dev/null)"
    if [ -n "$git_toplevel" ] && [ "$git_toplevel" != "$AL_REPO" ]; then
      worktree_dir="$git_toplevel"
    else
      worktree_dir="$(tmux display-message -p '#{session_path}' 2>/dev/null)"
    fi
  fi

  # Resolve to absolute path early
  if [ -n "$worktree_dir" ]; then
    if [ ! -d "$worktree_dir" ]; then
      echo "Directory not found: $worktree_dir"
      return 1
    fi
    worktree_dir="$(realpath "$worktree_dir")"
  fi

  if [ -z "$worktree_dir" ] || [ "$worktree_dir" = "$AL_REPO" ]; then
    echo "Usage: alwt-stop [--force] [worktree-dir]  (or run from within a worktree tmux session)"
    return 1
  fi

  echo "Will remove worktree: $worktree_dir"
  printf "Continue? [y/N] "
  read -r confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    return 1
  fi

  local session_name="$(basename "$worktree_dir")"
  if ! tmux has-session -t "$session_name" 2>/dev/null; then
    echo "No tmux session '$session_name' found, running cleanup only"
    bash "$AL_REPO/bin/cleanup-worktree.sh" $force "$worktree_dir"
    return
  fi

  local windows
  windows=$(tmux list-windows -t "$session_name" -F '#{window_id}')
  for w in $windows; do
    tmux kill-window -t "$w" 2>/dev/null
  done

  tmux new-window -t "$session_name" -n "cleanup" -c "$AL_REPO" \
    "bash bin/cleanup-worktree.sh $force '$worktree_dir'; echo; echo 'Press enter to close session...'; read; tmux kill-session -t '$session_name'"
  tmux select-window -t "$session_name:cleanup"
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
}

# ── Generic worktree management ─────────────────────────────
# Works with any project that has bin/wt-setup.sh (and optional bin/wt-stop.sh).
# Worktrees are placed in <repo>-worktrees/<branch> as siblings of the main repo.

wt() {
  if [ $# -eq 0 ] || { [ $# -eq 1 ] && [ "$1" = "." ]; }; then
    local git_root
    git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
      echo "Not in a git repo"
      return 1
    }
    cts "$git_root"
    return
  fi

  local branch_name="$1"

  # Find the main worktree (first entry in git worktree list)
  local main_repo
  main_repo="$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
  if [ -z "$main_repo" ]; then
    main_repo="$(git rev-parse --show-toplevel 2>/dev/null)" || {
      echo "Not in a git repo"
      return 1
    }
  fi

  local repo_name="$(basename "$main_repo")"
  local worktree_dir

  if [ -d "$branch_name" ]; then
    worktree_dir="$(cd "$branch_name" && pwd)"
  else
    worktree_dir="$(dirname "$main_repo")/${repo_name}-worktrees/$branch_name"
  fi

  if [ ! -d "$worktree_dir" ]; then
    (
      cd "$main_repo" || exit 1
      if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        git worktree add "$worktree_dir" "$branch_name"
      elif git show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
        git worktree add --track -b "$branch_name" "$worktree_dir" "origin/$branch_name"
      else
        git worktree add -b "$branch_name" "$worktree_dir" "origin/main"
      fi
    ) || return 1
  fi

  if [ -x "$worktree_dir/bin/wt-setup.sh" ]; then
    (cd "$worktree_dir" && bash bin/wt-setup.sh) || return 1
  fi

  cts "$worktree_dir"
}

wt-stop() {
  local force="" worktree_dir=""
  while [ $# -gt 0 ]; do
    case "$1" in
    --force | -f)
      force="--force"
      shift
      ;;
    *)
      worktree_dir="$1"
      shift
      ;;
    esac
  done

  # Resolve target worktree: explicit arg > current git root (if secondary) > tmux session path
  if [ -z "$worktree_dir" ]; then
    local git_toplevel main_wt
    git_toplevel="$(git rev-parse --show-toplevel 2>/dev/null)"
    main_wt="$(git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
    if [ -n "$git_toplevel" ] && [ "$git_toplevel" != "$main_wt" ]; then
      worktree_dir="$git_toplevel"
    else
      worktree_dir="$(tmux display-message -p '#{session_path}' 2>/dev/null)"
    fi
  fi

  # Resolve to absolute path early
  if [ -n "$worktree_dir" ]; then
    if [ ! -d "$worktree_dir" ]; then
      echo "Directory not found: $worktree_dir"
      return 1
    fi
    worktree_dir="$(realpath "$worktree_dir")"
  fi

  # Verify it's actually a worktree (not the main repo)
  local main_repo
  main_repo="$(cd "$worktree_dir" 2>/dev/null && git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')"
  if [ -z "$worktree_dir" ] || [ "$worktree_dir" = "$main_repo" ]; then
    echo "Usage: wt-stop [--force] [worktree-dir]  (or run from within a worktree tmux session)"
    return 1
  fi

  echo "Will remove worktree: $worktree_dir"
  printf "Continue? [y/N] "
  read -r confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    return 1
  fi

  # Run project-specific stop script if it exists (from main repo)
  if [ -n "$main_repo" ] && [ -x "$main_repo/bin/wt-stop.sh" ]; then
    bash "$main_repo/bin/wt-stop.sh" "$worktree_dir" || true
  fi

  local session_name="$(basename "$worktree_dir")"
  if ! tmux has-session -t "$session_name" 2>/dev/null; then
    echo "No tmux session '$session_name' found, removing worktree only"
    (cd "$main_repo" && git worktree remove $force "$worktree_dir")
    return
  fi

  local windows
  windows=$(tmux list-windows -t "$session_name" -F '#{window_id}')
  for w in $windows; do
    tmux kill-window -t "$w" 2>/dev/null
  done

  tmux new-window -t "$session_name" -n "cleanup" -c "$main_repo" \
    "git worktree remove $force '$worktree_dir'; echo; echo 'Press enter to close session...'; read; tmux kill-session -t '$session_name'"
  tmux select-window -t "$session_name:cleanup"
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
}

# ── Auto-reload shell config ────────────────────────────────
# When ~/.shell-auto-reload is touched, all open shells re-source on next prompt.
# chezmoi apply touches this file automatically via run_onchange script.
_SHELL_RELOAD_FILE="$HOME/.shell-auto-reload"
_SHELL_RELOAD_MTIME=""
_shell_reload_check() {
  local mtime
  if [ -f "$_SHELL_RELOAD_FILE" ]; then
    case "$_CURRENT_OS" in
    Darwin) mtime="$(stat -f %m "$_SHELL_RELOAD_FILE")" ;;
    *) mtime="$(stat -c %Y "$_SHELL_RELOAD_FILE")" ;;
    esac
  else
    return
  fi
  if [ -n "$_SHELL_RELOAD_MTIME" ] && [ "$mtime" != "$_SHELL_RELOAD_MTIME" ]; then
    _SHELL_RELOAD_MTIME="$mtime"
    echo "[shellrc] Reloading config..."
    source "$HOME/.${_CURRENT_SHELL}rc"
    return
  fi
  _SHELL_RELOAD_MTIME="$mtime"
}
# Register the check for both zsh (precmd) and bash (PROMPT_COMMAND)
if [ -n "$ZSH_VERSION" ]; then
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _shell_reload_check
elif [ -n "$BASH_VERSION" ]; then
  PROMPT_COMMAND="_shell_reload_check${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
fi

# ── Terminal title (hostname + cwd) ─────────────────────────
# Shows "host:~/path" when SSH'd, just "~/path" when local.
# Updates on each prompt via precmd/PROMPT_COMMAND.
# Falls back to tmux global env for SSH_CONNECTION (detect-remote.sh propagates it).
_update_terminal_title() {
  local title prefix="" is_ssh="$SSH_CONNECTION"
  if [ -f /.dockerenv ] || [ -n "$container" ]; then
    prefix="[container] "
  fi
  if [ -z "$is_ssh" ] && [ -n "$TMUX" ]; then
    is_ssh=$(tmux show-environment -g SSH_CONNECTION 2>/dev/null | grep -v '^-' | cut -d= -f2-)
  fi
  if [ -n "$is_ssh" ]; then
    title="${prefix}$(hostname -s):${PWD/#$HOME/~}"
  else
    title="${prefix}${PWD/#$HOME/~}"
  fi
  printf '\e]0;%s\a' "$title"
}
if [ -n "$ZSH_VERSION" ]; then
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _update_terminal_title
elif [ -n "$BASH_VERSION" ]; then
  PROMPT_COMMAND="_update_terminal_title${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
fi

