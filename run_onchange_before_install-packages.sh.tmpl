{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Install Homebrew packages (idempotent via brew bundle)
# packages hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

if ! command -v brew >/dev/null 2>&1; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range .packages.common -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

# Install fnm-managed Node.js if not present
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
  if ! fnm ls | grep -q "default"; then
    echo "Installing Node.js LTS via fnm..."
    fnm install --lts
    fnm default lts-latest
  fi
fi

{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Install packages for Linux
# packages hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

{{ if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") -}}
sudo apt-get update
sudo apt-get install -y \
{{ range .packages.common -}}
  {{ . }} \
{{ end -}}
{{ range .packages.debian -}}
  {{ . }} \
{{ end -}}
  ;

{{ else if eq .chezmoi.osRelease.id "arch" -}}
if ! command -v yay >/dev/null 2>&1; then
  echo "yay not found. Installing..."
  sudo pacman -S --needed --noconfirm base-devel git
  git clone https://aur.archlinux.org/yay.git /tmp/yay-install
  (cd /tmp/yay-install && makepkg -si --noconfirm)
  rm -rf /tmp/yay-install
fi

yay -S --needed --noconfirm \
{{ range .packages.common -}}
  {{ . }} \
{{ end -}}
{{ range .packages.arch -}}
  {{ . }} \
{{ end -}}
  ;

{{ end -}}

# Install fnm (not in apt/pacman)
if ! command -v fnm >/dev/null 2>&1; then
  echo "Installing fnm..."
  curl -fsSL https://fnm.vercel.app/install | bash
fi

# Install fnm-managed Node.js if not present
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
  if ! fnm ls | grep -q "default"; then
    echo "Installing Node.js LTS via fnm..."
    fnm install --lts
    fnm default lts-latest
  fi
fi

{{ end -}}
